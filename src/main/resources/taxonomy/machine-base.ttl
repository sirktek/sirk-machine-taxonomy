# Machine Taxonomy Base Schema in RDF-S (Turtle format)

@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix schema:  <https://schema.org/> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix machine: <http://taxonomy.sirktek.no/machine#> .
# v3.0: machine:manufacturer and machine:model now reference the
# cross-cutting common:Manufacturer / common:Model classes from
# common-taxonomy, resolved at merge time.
@prefix common:  <http://taxonomy.sirktek.no/common#> .

# ===================================================================
# Root Machine Class
# ===================================================================

machine:Machine a rdfs:Class ;
    rdfs:label "Machine"@en, "Maskin"@no ;
    rdfs:comment "Root class for all machines and powered equipment"@en .

# ===================================================================
# Level 1 Categories - Domain Groupings
# Additional level-1 groupings (e.g. Computer) can be added here.
# ===================================================================

machine:WoodshopMachine a rdfs:Class ;
    rdfs:subClassOf machine:Machine ;
    rdfs:label "Woodshop Machine"@en, "Trebearbeiding"@no ;
    rdfs:comment "Machines used in a woodshop or carpentry workshop"@en .

machine:TextileMachine a rdfs:Class ;
    rdfs:subClassOf machine:Machine ;
    rdfs:label "Textile Machine"@en, "Tekstilmaskin"@no ;
    rdfs:comment "Machines used for working with textiles and fabrics"@en .

# ===================================================================
# Level 2 Categories - Woodshop Machine Groups
# Functional groupings of woodshop machines. Specific machine types are
# defined as level-3 subclasses below.
# ===================================================================

machine:Saw a rdfs:Class ;
    rdfs:subClassOf machine:WoodshopMachine ;
    rdfs:label "Saw"@en, "Sag"@no ;
    rdfs:comment "Sawing machines for cutting wood and panels (panel saws, bench/circular saws, etc.)"@en .

machine:MillingMachine a rdfs:Class ;
    rdfs:subClassOf machine:WoodshopMachine ;
    rdfs:label "Milling Machine"@en, "Fres"@no ;
    skos:altLabel "Router"@en, "Moulder"@en ;
    rdfs:comment "Milling, routing and moulding machines, including CNC routers, spindle moulders and biscuit/lamello jointers"@en .

machine:Sander a rdfs:Class ;
    rdfs:subClassOf machine:WoodshopMachine ;
    rdfs:label "Sander"@en, "Pussemaskin"@no ;
    skos:altLabel "Sliper"@no ;
    rdfs:comment "Sanding and finishing machines (wide-belt sanders, etc.)"@en .

machine:Press a rdfs:Class ;
    rdfs:subClassOf machine:WoodshopMachine ;
    rdfs:label "Press"@en, "Presse"@no ;
    rdfs:comment "Woodworking press for gluing, veneering or clamping assemblies"@en .

machine:EdgeMachine a rdfs:Class ;
    rdfs:subClassOf machine:WoodshopMachine ;
    rdfs:label "Edge Machine"@en, "Kantmaskin"@no ;
    skos:altLabel "Edge Processing Machine"@en ;
    rdfs:comment "Edge-processing machines: edge banders and edge trimmers"@en .

# ===================================================================
# Level 2 Categories - Woodshop Machines (ungrouped)
# ===================================================================

machine:HandheldTool a rdfs:Class ;
    rdfs:subClassOf machine:WoodshopMachine ;
    rdfs:label "Handheld Tool"@en, "Håndholdt verktøy"@no ;
    skos:altLabel "Power Tool"@en ;
    rdfs:comment "Portable, hand-operated powered tools (drills, sanders, jigsaws, etc.)"@en .

machine:PlanerThicknesser a rdfs:Class ;
    rdfs:subClassOf machine:WoodshopMachine ;
    rdfs:label "Combined Planer-Thicknesser"@en, "Avretter-/tykkelseshøvel"@no ;
    skos:altLabel "Jointer-Planer"@en, "Kombihøvel"@no ;
    rdfs:comment "Combined surface planer (jointer) and thickness planer in one body (e.g. SD 410)"@en .

machine:VacuumLifter a rdfs:Class ;
    rdfs:subClassOf machine:WoodshopMachine ;
    rdfs:label "Vacuum Lifter"@en, "Vakuumløfter"@no ;
    skos:altLabel "Vacuum Panel Lifter"@en, "Vakumløfter"@no ;
    rdfs:comment "Vacuum-powered lifting aid for handling large flat workpieces such as panels and sheets"@en .

machine:SprayEquipment a rdfs:Class ;
    rdfs:subClassOf machine:WoodshopMachine ;
    rdfs:label "Spray Finishing Equipment"@en, "Lakkeringsutstyr"@no ;
    skos:altLabel "Spray Gun"@en, "Lakksprøyte"@no ;
    rdfs:comment "Spray gun / spray finishing equipment for applying lacquer or paint to surfaces"@en .

# ===================================================================
# Level 3 Categories - Saws (Sag)
# ===================================================================

machine:HydraulicSaw a rdfs:Class ;
    rdfs:subClassOf machine:Saw ;
    rdfs:label "Hydraulic Saw"@en, "Hydraulisk sag"@no ;
    rdfs:comment "Hydraulically-driven saw for cutting wood or other materials"@en .

machine:PanelSaw a rdfs:Class ;
    rdfs:subClassOf machine:Saw ;
    rdfs:label "Panel Saw"@en, "Formatsag"@no ;
    skos:altLabel "Sliding Table Saw"@en, "Skyvebordsag"@no ;
    rdfs:comment "Sliding-table circular saw for accurate sizing of panels and solid wood (e.g. Martin formatsag T60)"@en .

machine:BenchSaw a rdfs:Class ;
    rdfs:subClassOf machine:Saw ;
    rdfs:label "Bench Saw"@en, "Bordsag"@no ;
    skos:altLabel "Table Circular Saw"@en, "Bordsirkelsag"@no ;
    rdfs:comment "Fixed-table circular saw for ripping and crosscutting stock (e.g. Lazzari CS-41)"@en .

# ===================================================================
# Level 3 Categories - Milling machines (Fres)
# ===================================================================

machine:CNCMachine a rdfs:Class ;
    rdfs:subClassOf machine:MillingMachine ;
    rdfs:label "CNC Machine"@en, "CNC-maskin"@no ;
    skos:altLabel "Computer Numerical Control Machine"@en ;
    rdfs:comment "Computer numerical control machine for automated cutting, milling, or routing"@en .

machine:SpindleMoulder a rdfs:Class ;
    rdfs:subClassOf machine:MillingMachine ;
    rdfs:label "Spindle Moulder"@en, "Toppfres"@no ;
    skos:altLabel "Shaper"@en, "Fresemaskin"@no, "Spindelfres"@no ;
    rdfs:comment "Vertical-spindle moulder for profiling edges, grooves and tenons (e.g. Lazzari Base 45)"@en .

machine:BiscuitJointer a rdfs:Class ;
    rdfs:subClassOf machine:MillingMachine ;
    rdfs:label "Biscuit Jointer"@en, "Lamellfres"@no ;
    skos:altLabel "Lamello Jointer"@en ;
    rdfs:comment "Mills crescent-shaped grooves for flat biscuit (lamello) joints; may be a custom/special machine"@en .

# ===================================================================
# Level 3 Categories - Sanders (Pussemaskin)
# ===================================================================

machine:WideBeltSander a rdfs:Class ;
    rdfs:subClassOf machine:Sander ;
    rdfs:label "Wide-Belt Sander"@en, "Bredbåndspusser"@no ;
    skos:altLabel "Bredbåndssliper"@no ;
    rdfs:comment "Through-feed wide-belt sander for calibrating and finishing panels and solid wood (e.g. SCM DMC SD 60)"@en .

# ===================================================================
# Level 3 Categories - Edge machines (Kantmaskin)
# ===================================================================

machine:EdgeBander a rdfs:Class ;
    rdfs:subClassOf machine:EdgeMachine ;
    rdfs:label "Edge Banding Machine"@en, "Kantlimer"@no ;
    skos:altLabel "Edgebander"@en, "Kantlister"@no ;
    rdfs:comment "Applies edge tape/banding to panel edges with hot-melt or PUR glue (e.g. Felder G 380, Format-4 Tempora 45.03, SCM Minimax E10)"@en .

machine:EdgeTrimmer a rdfs:Class ;
    rdfs:subClassOf machine:EdgeMachine ;
    rdfs:label "Edge Trimmer"@en, "Kanttrimmer"@no ;
    skos:altLabel "Kantfresemaskin"@no ;
    rdfs:comment "Flush/bevel-trims shaped panel edges as an edge-finishing step (e.g. SCM Minimax T20)"@en .

# ===================================================================
# Level 4 Categories - CNC Machines
# ===================================================================

machine:TwoAxisCNCMachine a rdfs:Class ;
    rdfs:subClassOf machine:CNCMachine ;
    rdfs:label "2-Axis CNC Machine"@en, "2-akset CNC-maskin"@no ;
    skos:altLabel "Two Axis CNC"@en ;
    rdfs:comment "CNC machine with two controllable axes (typically X and Y)"@en .

machine:FiveAxisCNCMachine a rdfs:Class ;
    rdfs:subClassOf machine:CNCMachine ;
    rdfs:label "5-Axis CNC Machine"@en, "5-akset CNC-maskin"@no ;
    skos:altLabel "Five Axis CNC"@en ;
    rdfs:comment "CNC machine with five controllable axes (X, Y, Z plus two rotational)"@en .

# ===================================================================
# Level 3 Categories - Presses
# ===================================================================

machine:CaseClamp a rdfs:Class ;
    rdfs:subClassOf machine:Press ;
    rdfs:label "Case Clamp"@en, "Skrogpresse"@no ;
    skos:altLabel "Carcase Press"@en, "Korpuspresse"@no ;
    rdfs:comment "Electro-mechanical clamp that squares and glue-clamps assembled cabinet carcases (e.g. Bonacin Nina)"@en .

machine:GluePress a rdfs:Class ;
    rdfs:subClassOf machine:Press ;
    rdfs:label "Glue Press"@en, "Limpresse"@no ;
    skos:altLabel "Veneer Press"@en, "Finerpresse"@no ;
    rdfs:comment "Hydraulic platen press for pressing veneer and gluing/clamping panels under pressure (e.g. Höfer HP 65 S)"@en .

# ===================================================================
# Level 2 Categories - Textile Machines
# ===================================================================

machine:SewingMachine a rdfs:Class ;
    rdfs:subClassOf machine:TextileMachine ;
    rdfs:label "Sewing Machine"@en, "Symaskin"@no ;
    rdfs:comment "Machine for stitching fabric and other materials together with thread"@en .

machine:FabricCuttingMachine a rdfs:Class ;
    rdfs:subClassOf machine:TextileMachine ;
    rdfs:label "Fabric Cutting Machine"@en, "Stoffskjæremaskin"@no ;
    skos:altLabel "Cloth Cutting Machine"@en ;
    rdfs:comment "Machine for cutting fabric, textiles or cloth to size"@en .

# ===================================================================
# Power Source Enumeration
# ===================================================================

machine:PowerSource a rdfs:Class ;
    rdfs:label "Power Source"@en, "Energikilde"@no ;
    rdfs:comment "Enumeration of power sources used by machines"@en .

machine:Electric a machine:PowerSource ;
    rdfs:label "Electric"@en, "Elektrisk"@no ;
    rdfs:comment "Electrically powered"@en .

machine:Hydraulic a machine:PowerSource ;
    rdfs:label "Hydraulic"@en, "Hydraulisk"@no ;
    rdfs:comment "Hydraulically powered"@en .

machine:Pneumatic a machine:PowerSource ;
    rdfs:label "Pneumatic"@en, "Pneumatisk"@no ;
    rdfs:comment "Pneumatically powered (compressed air)"@en .

machine:BatteryPowered a machine:PowerSource ;
    rdfs:label "Battery Powered"@en, "Batteridrevet"@no ;
    rdfs:comment "Powered by rechargeable battery"@en .

machine:Manual a machine:PowerSource ;
    rdfs:label "Manual"@en, "Manuell"@no ;
    rdfs:comment "Human powered, no external power source"@en .

# ===================================================================
# Operational Status Enumeration
# ===================================================================

machine:OperationalStatus a rdfs:Class ;
    rdfs:label "Operational Status"@en, "Driftsstatus"@no ;
    rdfs:comment "Enumeration of operational states for a machine"@en .

machine:Operational a machine:OperationalStatus ;
    rdfs:label "Operational"@en, "I drift"@no ;
    rdfs:comment "Machine is in working order and operational"@en .

machine:NeedsService a machine:OperationalStatus ;
    rdfs:label "Needs Service"@en, "Trenger service"@no ;
    rdfs:comment "Machine is functional but requires maintenance"@en .

machine:Broken a machine:OperationalStatus ;
    rdfs:label "Broken"@en, "Defekt"@no ;
    rdfs:comment "Machine is broken and non-functional"@en .

machine:Retired a machine:OperationalStatus ;
    rdfs:label "Retired"@en, "Pensjonert"@no ;
    rdfs:comment "Machine has been retired from service"@en .

# ===================================================================
# Property Definitions - Common
# ===================================================================

machine:yearOfManufacture a rdf:Property ;
    rdfs:label "Year of Manufacture"@en, "Produksjonsår"@no ;
    rdfs:domain machine:Machine ;
    rdfs:range xsd:integer .

machine:variant a rdf:Property ;
    rdfs:label "Variant"@en, "Variant"@no ;
    rdfs:domain machine:Machine ;
    rdfs:range xsd:string .

machine:serialNumber a rdf:Property ;
    rdfs:label "Serial Number"@en, "Serienummer"@no ;
    rdfs:domain machine:Machine ;
    rdfs:range xsd:string .

machine:color a rdf:Property ;
    rdfs:label "Color"@en, "Farge"@no ;
    rdfs:domain machine:Machine ;
    rdfs:range xsd:string .

machine:material a rdf:Property ;
    rdfs:label "Material"@en, "Materiale"@no ;
    rdfs:domain machine:Machine ;
    rdfs:range xsd:string .

# ===================================================================
# Property Definitions - Dimensions and Weight
# ===================================================================

machine:weight a rdf:Property ;
    rdfs:label "Weight (kg)"@en, "Vekt (kg)"@no ;
    rdfs:domain machine:Machine ;
    rdfs:range xsd:decimal .

machine:length a rdf:Property ;
    rdfs:label "Length (cm)"@en, "Lengde (cm)"@no ;
    rdfs:domain machine:Machine ;
    rdfs:range xsd:decimal .

machine:width a rdf:Property ;
    rdfs:label "Width (cm)"@en, "Bredde (cm)"@no ;
    rdfs:domain machine:Machine ;
    rdfs:range xsd:decimal .

machine:height a rdf:Property ;
    rdfs:label "Height (cm)"@en, "Høyde (cm)"@no ;
    rdfs:domain machine:Machine ;
    rdfs:range xsd:decimal .

machine:volume a rdf:Property ;
    rdfs:label "Volume (m³)"@en, "Volum (m³)"@no ;
    rdfs:domain machine:Machine ;
    rdfs:range xsd:decimal .

# ===================================================================
# Property Definitions - Machine specific
# ===================================================================

machine:powerSource a rdf:Property ;
    rdfs:label "Power Source"@en, "Energikilde"@no ;
    rdfs:comment "The power source used by the machine"@en ;
    rdfs:domain machine:Machine ;
    rdfs:range machine:PowerSource .

machine:powerConsumption a rdf:Property ;
    rdfs:label "Power Consumption (kW)"@en, "Effektforbruk (kW)"@no ;
    rdfs:domain machine:Machine ;
    rdfs:range xsd:decimal .

machine:voltage a rdf:Property ;
    rdfs:label "Voltage (V)"@en, "Spenning (V)"@no ;
    rdfs:domain machine:Machine ;
    rdfs:range xsd:decimal .

machine:maxSpeed a rdf:Property ;
    rdfs:label "Max Speed (RPM)"@en, "Maks hastighet (RPM)"@no ;
    rdfs:comment "Maximum rotational speed in revolutions per minute"@en ;
    rdfs:domain machine:Machine ;
    rdfs:range xsd:decimal .

machine:operationalStatus a rdf:Property ;
    rdfs:label "Operational Status"@en, "Driftsstatus"@no ;
    rdfs:domain machine:Machine ;
    rdfs:range machine:OperationalStatus .

machine:operatingHours a rdf:Property ;
    rdfs:label "Operating Hours"@en, "Driftstimer"@no ;
    rdfs:comment "Total accumulated operating hours"@en ;
    rdfs:domain machine:Machine ;
    rdfs:range xsd:decimal .

# ===================================================================
# Property Definitions - CNC specific
# ===================================================================

machine:numberOfAxes a rdf:Property ;
    rdfs:label "Number of Axes"@en, "Antall akser"@no ;
    rdfs:comment "Number of controllable axes on a CNC machine"@en ;
    rdfs:domain machine:CNCMachine ;
    rdfs:range xsd:integer .

machine:workingAreaLength a rdf:Property ;
    rdfs:label "Working Area Length (cm)"@en, "Arbeidsområde lengde (cm)"@no ;
    schema:domainIncludes machine:CNCMachine ;
    schema:domainIncludes machine:HydraulicSaw ;
    schema:domainIncludes machine:FabricCuttingMachine ;
    rdfs:range xsd:decimal .

machine:workingAreaWidth a rdf:Property ;
    rdfs:label "Working Area Width (cm)"@en, "Arbeidsområde bredde (cm)"@no ;
    schema:domainIncludes machine:CNCMachine ;
    schema:domainIncludes machine:HydraulicSaw ;
    schema:domainIncludes machine:FabricCuttingMachine ;
    rdfs:range xsd:decimal .

# ===================================================================
# Property Definitions - Cutting specific
# ===================================================================

machine:maxCuttingThickness a rdf:Property ;
    rdfs:label "Max Cutting Thickness (cm)"@en, "Maks skjæretykkelse (cm)"@no ;
    schema:domainIncludes machine:HydraulicSaw ;
    schema:domainIncludes machine:CNCMachine ;
    schema:domainIncludes machine:FabricCuttingMachine ;
    rdfs:range xsd:decimal .

# ===================================================================
# Property Definitions - Sewing specific
# ===================================================================

machine:needleType a rdf:Property ;
    rdfs:label "Needle Type"@en, "Nåletype"@no ;
    rdfs:domain machine:SewingMachine ;
    rdfs:range xsd:string .

machine:stitchTypes a rdf:Property ;
    rdfs:label "Stitch Types"@en, "Stingtyper"@no ;
    rdfs:comment "Comma-separated list of supported stitch types"@en ;
    rdfs:domain machine:SewingMachine ;
    rdfs:range xsd:string .

machine:operationsAndMaintenanceManual a rdf:Property ;
    rdfs:label "Operations and Maintenance Manual"@en, "Drift- og vedlikeholdshåndbok"@no ;
    schema:domainIncludes machine:Machine ;
    rdfs:range xsd:anyURI .

machine:model a rdf:Property ;
    rdfs:label "Model"@en, "Modell"@no ;
    rdfs:domain machine:Machine ;
    rdfs:range common:Model .

machine:manufacturer a rdf:Property ;
    rdfs:label "Manufacturer"@en, "Produsent"@no ;
    rdfs:domain machine:Machine ;
    rdfs:range common:Manufacturer .

# ===================================================================
# Cross-cutting property domain extensions
#
# Opt machine:Machine into common cross-cutting properties by extending
# their domain with an additional schema:domainIncludes triple. The
# property and its range marker live in common-taxonomy.
# ===================================================================

common:assetValue schema:domainIncludes machine:Machine .
